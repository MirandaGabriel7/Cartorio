{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "JSON Schema for parser_sketch/catalogo_ancoras.json. Contract: .claude/schemas/anchors-catalog.md. Sub-objects with relaxed additionalProperties: (1) tipos_documento[*].ancoras — keys are dynamic canonical field names (transmitente_1_cpf, onus_N_tipo, matricula_numero, etc.) defined by Section 17 of the plan; statically enumerating them would prevent valid entries. Coverage constraints (>= 80%) and critical-field membership are enforced by validator script.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "versao", "data", "corpus_analisado", "tipos_documento", "cobertura"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "catalogo_ancoras_schema"
    },
    "versao": {
      "type": "string",
      "const": "1.0"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "corpus_analisado": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_documentos", "escrituras", "matriculas"],
      "properties": {
        "total_documentos": { "type": "integer", "minimum": 0 },
        "escrituras":        { "type": "integer", "minimum": 0 },
        "matriculas":        { "type": "integer", "minimum": 0 }
      }
    },
    "tipos_documento": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ESCRITURA_COMPRA_VENDA", "MATRICULA"],
      "properties": {
        "ESCRITURA_COMPRA_VENDA": { "$ref": "#/definitions/TipoDocumentoAncoras" },
        "MATRICULA":              { "$ref": "#/definitions/TipoDocumentoAncoras" }
      }
    },
    "cobertura": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_campos_secao_17",
        "campos_com_ancoras_publicadas",
        "cobertura_campos_pct",
        "cobertura_documentos_pct"
      ],
      "properties": {
        "total_campos_secao_17":          { "type": "integer", "minimum": 0 },
        "campos_com_ancoras_publicadas":  { "type": "integer", "minimum": 0 },
        "cobertura_campos_pct":           { "type": "number", "minimum": 0, "maximum": 100 },
        "cobertura_documentos_pct":       { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  },
  "definitions": {
    "TipoDocumentoAncoras": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ancoras"],
      "properties": {
        "ancoras": {
          "$comment": "additionalProperties: true — keys are dynamic canonical field names (transmitente_1_cpf, matricula, onus_N_tipo, area, etc.) per Section 17 of the plan. Enumerating all valid keys statically is impractical and would reject future plan extensions.",
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/AnchorEntry" }
        }
      }
    },
    "AnchorEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "campo",
        "tipo_extracao",
        "ancoras_primarias",
        "ancoras_variantes_ocr",
        "regex_valor",
        "contexto_bloco",
        "frequencia_no_corpus",
        "total_documentos_analisados",
        "prioridade",
        "criticidade",
        "observacoes"
      ],
      "properties": {
        "campo": {
          "type": "string",
          "minLength": 1
        },
        "tipo_extracao": {
          "type": "string",
          "enum": ["REGEX_ROTULO", "PADRAO_FIXO", "HEURISTICA"]
        },
        "ancoras_primarias": {
          "$comment": "May be empty array only when tipo_extracao is PADRAO_FIXO.",
          "type": "array",
          "items": { "type": "string" }
        },
        "ancoras_variantes_ocr": {
          "type": "array",
          "items": { "type": "string" }
        },
        "regex_valor": {
          "$comment": "Must be a valid JavaScript regex string; validated by scripts/validar_corpus_catalog.ts via new RegExp().",
          "type": "string",
          "minLength": 1
        },
        "contexto_bloco": {
          "type": "string",
          "minLength": 1
        },
        "frequencia_no_corpus": {
          "$comment": "Must be <= total_documentos_analisados; enforced by validator script.",
          "type": "integer",
          "minimum": 0
        },
        "total_documentos_analisados": {
          "type": "integer",
          "minimum": 0
        },
        "prioridade": {
          "$comment": "1–15 per Section 7.1 of the plan.",
          "type": "integer",
          "minimum": 1,
          "maximum": 15
        },
        "criticidade": {
          "type": "string",
          "enum": ["CRITICO", "NAO_CRITICO"]
        },
        "observacoes": {
          "$comment": "Free-form notes on OCR artifacts, corner cases, Phase 1 flags. Empty string allowed, null is not.",
          "type": "string"
        }
      }
    }
  }
}
